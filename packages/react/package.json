{
  "name": "@pplancq/shelter-ui-react",
  "version": "1.0.0-alpha.7",
  "license": "MIT",
  "description": "Modular, scalable React components",
  "author": "pplancq <paul.plancq@outlook.fr>",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "https://github.com/pplancq/shelter-ui",
    "directory": "packages/react"
  },
  "bugs": {
    "url": "https://github.com/pplancq/shelter-ui/issues"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "homepage": "https://pplancq.github.io/shelter-ui/",
  "scripts": {
    "build": "rslib build",
    "dev": "rslib build --watch",
    "lint": "concurrently --prefix-colors auto \"npm:eslint\" \"npm:tsc\"",
    "eslint": "eslint \"{src,tests}/**/*.{js,jsx,ts,tsx}\"",
    "eslint:fix": "eslint \"{src,tests}/**/*.{js,jsx,ts,tsx}\" --fix",
    "tsc": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:unit": "vitest run --config tests/unit/vitest.config.mts",
    "test:browser": "vitest run --config tests/browser/vitest.config.mts",
    "test:visual": "vitest run --config tests/visual/vitest.config.mts",
    "postversion": "npm i --save-peer @pplancq/shelter-ui-icon@$npm_package_version && npm i --save-peer @pplancq/shelter-ui-css@$npm_package_version"
  },
  "engines": {
    "node": ">= 22"
  },
  "peerDependencies": {
    "@pplancq/shelter-ui-css": "^1.0.0-alpha.7",
    "@pplancq/shelter-ui-icon": "^1.0.0-alpha.7",
    "react": "^19.0.0"
  },
  "peerDependenciesMeta": {
    "@pplancq/shelter-ui-icon": {
      "optional": true
    }
  },
  "dependencies": {
    "@pplancq/svg-react": "^3.0.6"
  },
  "devDependencies": {
    "@pplancq/eslint-config": "^6.0.16",
    "@pplancq/prettier-config": "^3.0.0",
    "@rsbuild/plugin-react": "^2.0.0",
    "@rslib/core": "^0.22.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "^19.2.15",
    "@vitejs/plugin-react": "^6.0.2",
    "@vitest/browser": "^4.1.7",
    "@vitest/browser-playwright": "^4.1.5",
    "@vitest/coverage-v8": "^4.1.7",
    "@vitest/ui": "^4.1.7",
    "concurrently": "^10.0.0",
    "eslint": "^9.39.4",
    "eslint-plugin-prettier": "^5.5.6",
    "jsdom": "^29.1.1",
    "playwright": "^1.59.1",
    "prettier": "^3.8.3",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "typescript": "^6.0.3",
    "vitest": "^4.1.7",
    "vitest-browser-react": "^2.2.0",
    "vitest-sonar-reporter": "^3.0.0"
  },
  "prettier": "@pplancq/prettier-config",
  "lint-staged": {
    "*.(js|jsx|ts|tsx)": "eslint --fix",
    "*.{ts,tsx}": "tsc-files --noEmit",
    "*.!(js|jsx|ts|tsx)": "prettier --write --ignore-unknown"
  }
}
